From 6bfb34ce0fcb9de96840b90487e29703fa3c4087 Mon Sep 17 00:00:00 2001
From: edde746 <86283021+edde746@users.noreply.github.com>
Date: Thu, 7 May 2026 19:25:00 +0200
Subject: [PATCH] vo_avfoundation: tag software uploads with color metadata

Software-decoded P010 frames are copied into fresh CVPixelBuffers before
being enqueued into AVSampleBufferDisplayLayer. Preserve the mpv color
params on those buffers so CoreMedia can create HDR-aware sample
descriptions for software fallback and plain-HEVC HDR paths.
---
 video/out/vo_avfoundation.m | 87 ++++++++++++++++++++++++++++++++++++++++++++
 1 file changed, 87 insertions(+)

diff --git a/video/out/vo_avfoundation.m b/video/out/vo_avfoundation.m
--- a/video/out/vo_avfoundation.m
+++ b/video/out/vo_avfoundation.m
@@ -183,6 +183,90 @@ static bool create_output_pool(struct vo *vo, int w, int h, OSType format)
         &p->output_pool_h, NULL, w, h, outputFormat, "composite output");
 }
 
+static CFStringRef get_cv_color_primaries(enum pl_color_primaries primaries)
+{
+    switch (primaries) {
+    case PL_COLOR_PRIM_BT_709:
+        return kCVImageBufferColorPrimaries_ITU_R_709_2;
+    case PL_COLOR_PRIM_BT_2020:
+        return kCVImageBufferColorPrimaries_ITU_R_2020;
+    default:
+        return NULL;
+    }
+}
+
+static CFStringRef get_cv_transfer_function(enum pl_color_transfer transfer)
+{
+    switch (transfer) {
+    case PL_COLOR_TRC_SRGB:
+        return kCVImageBufferTransferFunction_sRGB;
+    case PL_COLOR_TRC_BT_1886:
+        return kCVImageBufferTransferFunction_ITU_R_709_2;
+    case PL_COLOR_TRC_PQ:
+        return kCVImageBufferTransferFunction_SMPTE_ST_2084_PQ;
+    case PL_COLOR_TRC_HLG:
+        return kCVImageBufferTransferFunction_ITU_R_2100_HLG;
+    default:
+        return NULL;
+    }
+}
+
+static CFStringRef get_cv_ycbcr_matrix(enum pl_color_system sys)
+{
+    switch (sys) {
+    case PL_COLOR_SYSTEM_BT_601:
+        return kCVImageBufferYCbCrMatrix_ITU_R_601_4;
+    case PL_COLOR_SYSTEM_BT_709:
+        return kCVImageBufferYCbCrMatrix_ITU_R_709_2;
+    case PL_COLOR_SYSTEM_BT_2020_NC:
+    case PL_COLOR_SYSTEM_BT_2020_C:
+    case PL_COLOR_SYSTEM_BT_2100_PQ:
+    case PL_COLOR_SYSTEM_BT_2100_HLG:
+        return kCVImageBufferYCbCrMatrix_ITU_R_2020;
+    default:
+        return NULL;
+    }
+}
+
+static void set_colorspace_from_attachments(CVPixelBufferRef pixbuf)
+{
+    CFDictionaryRef attachments = CVBufferGetAttachments(
+        pixbuf, kCVAttachmentMode_ShouldPropagate);
+    if (!attachments)
+        return;
+
+    CGColorSpaceRef colorspace = CVImageBufferCreateColorSpaceFromAttachments(attachments);
+    if (!colorspace)
+        return;
+
+    CVBufferSetAttachment(pixbuf, kCVImageBufferCGColorSpaceKey, colorspace,
+                          kCVAttachmentMode_ShouldPropagate);
+    CGColorSpaceRelease(colorspace);
+}
+
+static void tag_pixel_buffer_color_metadata(CVPixelBufferRef pixbuf,
+                                            const struct mp_image_params *params)
+{
+    CFStringRef primaries = get_cv_color_primaries(params->color.primaries);
+    CFStringRef transfer = get_cv_transfer_function(params->color.transfer);
+    CFStringRef matrix = get_cv_ycbcr_matrix(params->repr.sys);
+
+    if (primaries) {
+        CVBufferSetAttachment(pixbuf, kCVImageBufferColorPrimariesKey,
+                              primaries, kCVAttachmentMode_ShouldPropagate);
+    }
+    if (transfer) {
+        CVBufferSetAttachment(pixbuf, kCVImageBufferTransferFunctionKey,
+                              transfer, kCVAttachmentMode_ShouldPropagate);
+    }
+    if (matrix) {
+        CVBufferSetAttachment(pixbuf, kCVImageBufferYCbCrMatrixKey,
+                              matrix, kCVAttachmentMode_ShouldPropagate);
+    }
+    if (primaries || transfer || matrix)
+        set_colorspace_from_attachments(pixbuf);
+}
+
 // Copy HDR metadata from source to destination pixel buffer
 static void copy_hdr_metadata(CVPixelBufferRef src, CVPixelBufferRef dst)
 {
@@ -199,6 +281,8 @@ static void copy_hdr_metadata(CVPixelBufferRef src, CVPixelBufferRef dst)
             CVBufferSetAttachment(dst, keys[i], value, kCVAttachmentMode_ShouldPropagate);
         }
     }
+
+    set_colorspace_from_attachments(dst);
 }
 
 // Map mpv image format to CVPixelBuffer format
@@ -372,6 +456,7 @@ static CVPixelBufferRef upload_software_frame(struct vo *vo, struct mp_image *mp
     }
 
     CVPixelBufferUnlockBaseAddress(pixbuf, 0);
+    tag_pixel_buffer_color_metadata(pixbuf, &mpi->params);
 
     return pixbuf;
 }
