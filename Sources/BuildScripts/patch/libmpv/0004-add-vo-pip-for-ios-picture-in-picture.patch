diff --git a/video/out/vo_pip.m b/video/out/vo_pip.m
new file mode 100644
index 0000000..1b4921c
--- /dev/null
+++ b/video/out/vo_pip.m
@@ -0,0 +1,214 @@
+/*
+ * PiP video output — feeds CVPixelBuffers from VideoToolbox
+ * to an AVSampleBufferDisplayLayer for iOS/macOS Picture-in-Picture.
+ *
+ * WinID must point to an AVSampleBufferDisplayLayer instance.
+ *
+ * This VO only accepts IMGFMT_VIDEOTOOLBOX frames (hardware-decoded
+ * CVPixelBuffers). It wraps each frame in a CMSampleBuffer and
+ * enqueues it on the display layer.
+ *
+ * Provides its own VideoToolbox hwdec device context so that
+ * hardware decoding works without a GPU VO (no OpenGL/Vulkan needed).
+ *
+ * This file is part of mpv.
+ *
+ * mpv is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU Lesser General Public
+ * License as published by the Free Software Foundation; either
+ * version 2.1 of the License, or (at your option) any later version.
+ *
+ * mpv is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
+ * GNU Lesser General Public License for more details.
+ *
+ * You should have received a copy of the GNU Lesser General Public
+ * License along with mpv.  If not, see <http://www.gnu.org/licenses/>.
+ */
+
+#import <AVFoundation/AVFoundation.h>
+#import <CoreMedia/CoreMedia.h>
+#import <CoreVideo/CoreVideo.h>
+
+#include <libavutil/hwcontext.h>
+
+#include "common/msg.h"
+#include "video/img_format.h"
+#include "video/mp_image.h"
+#include "video/hwdec.h"
+#include "vo.h"
+
+struct priv {
+    AVSampleBufferDisplayLayer *layer;
+    CMTimebaseRef timebase;
+    struct mp_hwdec_ctx hwctx;
+};
+
+static CMSampleBufferRef create_sample_buffer(CVPixelBufferRef pixbuf, CMTimebaseRef timebase)
+{
+    if (!pixbuf)
+        return NULL;
+
+    CMVideoFormatDescriptionRef fmt_desc = NULL;
+    OSStatus status = CMVideoFormatDescriptionCreateForImageBuffer(
+        kCFAllocatorDefault, pixbuf, &fmt_desc);
+    if (status != noErr || !fmt_desc)
+        return NULL;
+
+    CMTime pts = CMTimebaseGetTime(timebase);
+    CMSampleTimingInfo timing = {
+        .duration = kCMTimeInvalid,
+        .presentationTimeStamp = pts,
+        .decodeTimeStamp = kCMTimeInvalid,
+    };
+
+    CMSampleBufferRef sample_buf = NULL;
+    status = CMSampleBufferCreateReadyWithImageBuffer(
+        kCFAllocatorDefault, pixbuf, fmt_desc, &timing, &sample_buf);
+    CFRelease(fmt_desc);
+
+    if (status != noErr)
+        return NULL;
+
+    CFArrayRef attachments = CMSampleBufferGetSampleAttachmentsArray(sample_buf, true);
+    if (attachments && CFArrayGetCount(attachments) > 0) {
+        CFMutableDictionaryRef dict =
+            (CFMutableDictionaryRef)CFArrayGetValueAtIndex(attachments, 0);
+        CFDictionarySetValue(dict,
+            kCMSampleAttachmentKey_DisplayImmediately, kCFBooleanTrue);
+    }
+
+    return sample_buf;
+}
+
+static int preinit(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    if (vo->opts->WinID == -1) {
+        MP_ERR(vo, "vo_pip requires --wid pointing to an AVSampleBufferDisplayLayer\n");
+        return -1;
+    }
+
+    p->layer = (__bridge AVSampleBufferDisplayLayer *)(void *)(intptr_t)vo->opts->WinID;
+    if (!p->layer) {
+        MP_ERR(vo, "vo_pip: invalid layer pointer\n");
+        return -1;
+    }
+
+    CMTimebaseRef timebase = NULL;
+    OSStatus status = CMTimebaseCreateWithSourceClock(
+        kCFAllocatorDefault, CMClockGetHostTimeClock(), &timebase);
+    if (status != noErr) {
+        MP_ERR(vo, "vo_pip: failed to create CMTimebase\n");
+        return -1;
+    }
+    CMTimebaseSetRate(timebase, 1.0);
+    CMTimebaseSetTime(timebase, kCMTimeZero);
+    p->timebase = timebase;
+
+    p->layer.controlTimebase = timebase;
+
+    // Register VideoToolbox hwdec device context so that hwdec=videotoolbox
+    // works with this VO (no GPU context needed for PiP).
+    p->hwctx = (struct mp_hwdec_ctx){
+        .driver_name = "pip",
+        .hw_imgfmt = IMGFMT_VIDEOTOOLBOX,
+    };
+
+    int ret = av_hwdevice_ctx_create(&p->hwctx.av_device_ref,
+                                     AV_HWDEVICE_TYPE_VIDEOTOOLBOX, NULL, NULL, 0);
+    if (ret != 0) {
+        MP_ERR(vo, "vo_pip: failed to create VideoToolbox device context\n");
+        CFRelease(timebase);
+        p->timebase = NULL;
+        return -1;
+    }
+
+    hwdec_devices_add(vo->hwdec_devs, &p->hwctx);
+
+    MP_VERBOSE(vo, "vo_pip: initialized with AVSampleBufferDisplayLayer\n");
+    return 0;
+}
+
+static int query_format(struct vo *vo, int format)
+{
+    return format == IMGFMT_VIDEOTOOLBOX;
+}
+
+static int reconfig(struct vo *vo, struct mp_image_params *params)
+{
+    return 0;
+}
+
+static bool draw_frame(struct vo *vo, struct vo_frame *frame)
+{
+    struct priv *p = vo->priv;
+
+    struct mp_image *img = frame->current;
+    if (!img)
+        return true;
+
+    CVPixelBufferRef pixbuf = (CVPixelBufferRef)img->planes[3];
+    if (!pixbuf) {
+        MP_WARN(vo, "vo_pip: frame has no CVPixelBuffer\n");
+        return true;
+    }
+
+    CMSampleBufferRef sample = create_sample_buffer(pixbuf, p->timebase);
+    if (!sample) {
+        MP_WARN(vo, "vo_pip: failed to create CMSampleBuffer\n");
+        return true;
+    }
+
+    if (p->layer.status == AVQueuedSampleBufferRenderingStatusFailed) {
+        MP_WARN(vo, "vo_pip: layer in failed state, flushing\n");
+        [p->layer flush];
+    }
+
+    [p->layer enqueueSampleBuffer:sample];
+    CFRelease(sample);
+
+    return true;
+}
+
+static void flip_page(struct vo *vo)
+{
+}
+
+static int control(struct vo *vo, uint32_t request, void *data)
+{
+    return VO_NOTIMPL;
+}
+
+static void uninit(struct vo *vo)
+{
+    struct priv *p = vo->priv;
+
+    hwdec_devices_remove(vo->hwdec_devs, &p->hwctx);
+    av_buffer_unref(&p->hwctx.av_device_ref);
+
+    if (p->layer) {
+        [p->layer flushAndRemoveImage];
+        p->layer.controlTimebase = NULL;
+    }
+    if (p->timebase) {
+        CFRelease(p->timebase);
+        p->timebase = NULL;
+    }
+}
+
+const struct vo_driver video_out_pip = {
+    .description = "PiP via AVSampleBufferDisplayLayer",
+    .name = "pip",
+    .caps = VO_CAP_NORETAIN,
+    .preinit = preinit,
+    .query_format = query_format,
+    .reconfig = reconfig,
+    .control = control,
+    .draw_frame = draw_frame,
+    .flip_page = flip_page,
+    .uninit = uninit,
+    .priv_size = sizeof(struct priv),
+};
