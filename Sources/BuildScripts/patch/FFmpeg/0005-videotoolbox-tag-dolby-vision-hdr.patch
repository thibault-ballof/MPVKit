From 9b0b21e341b7c5406a7e5e5b35e2d8f9b27e1a0f Mon Sep 17 00:00:00 2001
From: edde746 <86283021+edde746@users.noreply.github.com>
Date: Thu, 7 May 2026 17:30:00 +0200
Subject: [PATCH] videotoolbox: tag Dolby Vision output as HDR

Ensure Apple Dolby Vision VideoToolbox sessions advertise HDR color
description extensions and decoded pixel buffers carry BT.2020 HDR
attachments when the Dolby Vision stream has an HDR10/HLG-compatible
base layer. Profile 5 is left to VideoToolbox's native Dolby Vision
metadata because its base is not BT.2020 YCbCr. Also enable
VideoToolbox's per-frame HDR display metadata propagation/generation
where the OS supports it.
---
 libavcodec/videotoolbox.c | 121 ++++++++++++++++++++++++++++++++++++++
 1 file changed, 121 insertions(+)

diff --git a/libavcodec/videotoolbox.c b/libavcodec/videotoolbox.c
index 294fc4e..374a3c7 100644
--- a/libavcodec/videotoolbox.c
+++ b/libavcodec/videotoolbox.c
@@ -121,6 +121,8 @@ int ff_videotoolbox_buffer_append(VTContext *vtctx,
 }
 
 static int videotoolbox_dovi_should_preserve_attachments(AVCodecContext *avctx);
+static void videotoolbox_dovi_tag_output_attachments(AVCodecContext *avctx,
+                                                     CVPixelBufferRef pixbuf);
 
 static int videotoolbox_postproc_frame(void *avctx, AVFrame *frame)
 {
@@ -141,6 +143,7 @@ static int videotoolbox_postproc_frame(void *avctx, AVFrame *frame)
     if (!videotoolbox_dovi_should_preserve_attachments(avctx) &&
         (ret = av_vt_pixbuf_set_attachments(avctx, ref->pixbuf, frame)) < 0)
         return ret;
+    videotoolbox_dovi_tag_output_attachments(avctx, ref->pixbuf);
 
     frame->data[3] = (uint8_t*)ref->pixbuf;
 
@@ -872,6 +875,80 @@ static int videotoolbox_dovi_should_preserve_attachments(AVCodecContext *avctx)
     return videotoolbox_dovi_is_apple_hevc(videotoolbox_dovi_get_conf(avctx));
 }
 
+static int videotoolbox_dovi_is_hlg(const AVDOVIDecoderConfigurationRecord *dovi)
+{
+    return dovi && dovi->dv_profile == 8 &&
+           dovi->dv_bl_signal_compatibility_id == 4;
+}
+
+static int videotoolbox_dovi_has_hdr_compatible_base(const AVDOVIDecoderConfigurationRecord *dovi)
+{
+    return dovi && (dovi->dv_profile == 8 ||
+           (dovi->dv_profile == 7 && dovi->rpu_present_flag &&
+            dovi->bl_present_flag));
+}
+
+static CFDictionaryRef videotoolbox_copy_buffer_attachments(CVBufferRef buffer,
+                                                            CVAttachmentMode attachment_mode)
+{
+#if (TARGET_OS_OSX  && defined(__MAC_12_0)    && __MAC_OS_X_VERSION_MAX_ALLOWED  >= __MAC_12_0)    || \
+    (TARGET_OS_IOS  && defined(__IPHONE_15_0) && __IPHONE_OS_VERSION_MAX_ALLOWED >= __IPHONE_15_0) || \
+    (TARGET_OS_TV   && defined(__TVOS_15_0)   && __TV_OS_VERSION_MAX_ALLOWED     >= __TVOS_15_0)
+    if (__builtin_available(macOS 12.0, iOS 15.0, tvOS 15.0, *))
+        return CVBufferCopyAttachments(buffer, attachment_mode);
+#endif
+
+#if (TARGET_OS_OSX  && (!defined(__MAC_12_0)    || __MAC_OS_X_VERSION_MIN_REQUIRED  < __MAC_12_0))    || \
+    (TARGET_OS_IOS  && (!defined(__IPHONE_15_0) || __IPHONE_OS_VERSION_MIN_REQUIRED < __IPHONE_15_0)) || \
+    (TARGET_OS_TV   && (!defined(__TVOS_15_0)   || __TV_OS_VERSION_MIN_REQUIRED     < __TVOS_15_0))
+    CFDictionaryRef dict = CVBufferGetAttachments(buffer, attachment_mode);
+    return dict ? CFDictionaryCreateCopy(NULL, dict) : NULL;
+#else
+    return NULL;
+#endif
+}
+
+static void videotoolbox_dovi_tag_output_attachments(AVCodecContext *avctx,
+                                                     CVPixelBufferRef pixbuf)
+{
+    const AVDOVIDecoderConfigurationRecord *dovi = videotoolbox_dovi_get_conf(avctx);
+    CFDictionaryRef attachments;
+    CGColorSpaceRef colorspace;
+    CFStringRef transfer_function;
+
+    if (!videotoolbox_dovi_is_apple_hevc(dovi) ||
+        !videotoolbox_dovi_has_hdr_compatible_base(dovi))
+        return;
+
+    transfer_function = videotoolbox_dovi_is_hlg(dovi) ?
+                        kCVImageBufferTransferFunction_ITU_R_2100_HLG :
+                        kCVImageBufferTransferFunction_SMPTE_ST_2084_PQ;
+
+    CVBufferSetAttachment(pixbuf, kCVImageBufferColorPrimariesKey,
+                          kCVImageBufferColorPrimaries_ITU_R_2020,
+                          kCVAttachmentMode_ShouldPropagate);
+    CVBufferSetAttachment(pixbuf, kCVImageBufferTransferFunctionKey,
+                          transfer_function,
+                          kCVAttachmentMode_ShouldPropagate);
+    CVBufferSetAttachment(pixbuf, kCVImageBufferYCbCrMatrixKey,
+                          kCVImageBufferYCbCrMatrix_ITU_R_2020,
+                          kCVAttachmentMode_ShouldPropagate);
+
+    attachments = videotoolbox_copy_buffer_attachments(pixbuf,
+                                                       kCVAttachmentMode_ShouldPropagate);
+    if (!attachments)
+        return;
+
+    colorspace = CVImageBufferCreateColorSpaceFromAttachments(attachments);
+    CFRelease(attachments);
+    if (!colorspace)
+        return;
+
+    CVBufferSetAttachment(pixbuf, kCVImageBufferCGColorSpaceKey,
+                          colorspace, kCVAttachmentMode_ShouldPropagate);
+    CFRelease(colorspace);
+}
+
 static int videotoolbox_dovi_needs_p81_conversion(const AVDOVIDecoderConfigurationRecord *dovi)
 {
     return dovi && dovi->dv_profile == 7 &&
@@ -940,6 +1017,20 @@ static CFDictionaryRef videotoolbox_decoder_config_create(CMVideoCodecType codec
                             kVTVideoDecoderSpecification_RequireHardwareAcceleratedVideoDecoder,
                          kCFBooleanTrue);
 
+    if (codec_type == kCMVideoCodecType_DolbyVisionHEVC_FF) {
+        dovi = videotoolbox_dovi_get_conf(avctx);
+        if (videotoolbox_dovi_has_hdr_compatible_base(dovi)) {
+            CFDictionarySetValue(config_info, kCMFormatDescriptionExtension_ColorPrimaries,
+                                 kCMFormatDescriptionColorPrimaries_ITU_R_2020);
+            CFDictionarySetValue(config_info, kCMFormatDescriptionExtension_TransferFunction,
+                                 videotoolbox_dovi_is_hlg(dovi) ?
+                                    kCMFormatDescriptionTransferFunction_ITU_R_2100_HLG :
+                                    kCMFormatDescriptionTransferFunction_SMPTE_ST_2084_PQ);
+            CFDictionarySetValue(config_info, kCMFormatDescriptionExtension_YCbCrMatrix,
+                                 kCMFormatDescriptionYCbCrMatrix_ITU_R_2020);
+        }
+    }
+
     avc_info = CFDictionaryCreateMutable(kCFAllocatorDefault,
                                          1,
                                          &kCFTypeDictionaryKeyCallBacks,
@@ -1124,6 +1215,36 @@ static int videotoolbox_start(AVCodecContext *avctx)
                                           &decoder_cb,               // outputCallback
                                           &videotoolbox->session);   // decompressionSessionOut
 
+    if (!status && videotoolbox->cm_codec_type == kCMVideoCodecType_DolbyVisionHEVC_FF) {
+        OSStatus property_status;
+
+#if AV_HAS_BUILTIN(__builtin_available)
+        if (__builtin_available(macOS 11.0, iOS 14.0, tvOS 14.0, *)) {
+#endif
+            property_status = VTSessionSetProperty(videotoolbox->session,
+                                                   kVTDecompressionPropertyKey_PropagatePerFrameHDRDisplayMetadata,
+                                                   kCFBooleanTrue);
+            if (property_status)
+                av_log(avctx, AV_LOG_VERBOSE,
+                       "Failed to enable VideoToolbox HDR metadata propagation: %d\n",
+                       (int)property_status);
+#if AV_HAS_BUILTIN(__builtin_available)
+        }
+
+        if (__builtin_available(macOS 14.0, iOS 17.0, tvOS 17.0, *)) {
+#endif
+            property_status = VTSessionSetProperty(videotoolbox->session,
+                                                   kVTDecompressionPropertyKey_GeneratePerFrameHDRDisplayMetadata,
+                                                   kCFBooleanTrue);
+            if (property_status)
+                av_log(avctx, AV_LOG_VERBOSE,
+                       "Failed to enable VideoToolbox HDR metadata generation: %d\n",
+                       (int)property_status);
+#if AV_HAS_BUILTIN(__builtin_available)
+        }
+#endif
+    }
+
     if (decoder_spec)
         CFRelease(decoder_spec);
     if (buf_attr)
-- 
